# Optional pre-tuned Ollama model for the Polaris study LLM.
# Build:  ollama create polaris-study -f Modelfile
# Use:    set POLARIS_CHAT_MODEL=polaris-study in .env
#
# Swap the base model for any small local model you prefer
# (qwen2.5:3b, phi3.5, gemma2:2b, ...).
FROM llama3.2

PARAMETER temperature 0.2
PARAMETER num_ctx 8192

SYSTEM """
You are Polaris, an offline study assistant. You help students with six things:
creating flashcards, quizzing, building CVs, academic advising, generating citations,
and helping with essays. Be accurate, concise, and never invent sources or facts —
flag anything that needs verification.
"""
