# =============================================================================
# North Star (Polaris) — environment configuration
# Copy to `.env` and adjust. Everything has a sensible offline-first default,
# so the apps run with ZERO external API keys.
# =============================================================================

# ---------------------------------------------------------------------------
# Ollama (local LLM runtime). Default talks to a local Ollama daemon.
# Install: https://ollama.com  ->  `ollama serve`
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# Chat model used by the study LLM + fitness agents.
# Good small/offline options: llama3.2, qwen2.5:3b, phi3.5, gemma2:2b
POLARIS_CHAT_MODEL=llama3.2

# Embedding model used by the RAG vector DB. Pull with:
#   ollama pull nomic-embed-text
POLARIS_EMBED_MODEL=nomic-embed-text

# Generation controls
POLARIS_TEMPERATURE=0.2
POLARIS_NUM_CTX=8192
POLARIS_REQUEST_TIMEOUT=120

# ---------------------------------------------------------------------------
# Embedding backend: "ollama" (default) or "fastembed" (pure offline ONNX,
# requires the `offline-embeddings` extra: pip install -e ".[offline-embeddings]")
# ---------------------------------------------------------------------------
POLARIS_EMBED_BACKEND=ollama
# Used only when POLARIS_EMBED_BACKEND=fastembed
POLARIS_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# ---------------------------------------------------------------------------
# Vector DB (Chroma, embedded — stored on disk, no server needed)
# ---------------------------------------------------------------------------
POLARIS_CHROMA_DIR=.data/chroma
POLARIS_RAG_COLLECTION=study_notes
POLARIS_RAG_CHUNK_SIZE=1000
POLARIS_RAG_CHUNK_OVERLAP=150
POLARIS_RAG_TOP_K=4

# ---------------------------------------------------------------------------
# LangGraph persistence (conversation memory / resumable runs)
# ---------------------------------------------------------------------------
POLARIS_CHECKPOINT_DB=.data/checkpoints.sqlite

# ---------------------------------------------------------------------------
# Fitness athlete profile (optional). If set, HR zones use true %HRmax and
# training load uses heart-rate reserve. Leave blank to fall back to the
# observed peak HR in each file.
# ---------------------------------------------------------------------------
POLARIS_ATHLETE_AGE=
POLARIS_ATHLETE_RESTING_HR=
POLARIS_ATHLETE_MAX_HR=
POLARIS_FITNESS_DB=.data/fitness.sqlite

# Units for fitness output: "metric" (km, km/h, min/km) or "imperial" (mi, mph, min/mi)
POLARIS_UNITS=metric

# ---------------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING | ERROR
# ---------------------------------------------------------------------------
POLARIS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# OPTIONAL — cloud fallback. Leave blank to stay fully local/offline.
# The admin sets a key here AND flips POLARIS_ALLOW_CLOUD_FALLBACK on before
# any component will fail over to the cloud when Ollama is unreachable. The
# key itself is only ever read server-side (e.g. it powers the sidebar toggle
# in the Streamlit admin UI) — it is never exposed to end users.
# ---------------------------------------------------------------------------
GROQ_API_KEY=
OPENROUTER_API_KEY=
POLARIS_ALLOW_CLOUD_FALLBACK=false
